{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
